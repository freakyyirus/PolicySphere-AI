generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String      @id @default(uuid())
  email        String      @unique
  username     String
  password     String
  settings     String      @default("{}")
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  analyses     Analysis[]
}

model Analysis {
  id           String      @id @default(uuid())
  userId       String?
  title        String
  policyType   String
  sector       String
  magnitude    Float
  duration     String      @default("short")
  riskScore    Float
  decision     String
  explanation  String
  impacts      String
  policyLabel  String
  sectorLabel  String
  analyzedAt   DateTime    @default(now())
  user         User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
}